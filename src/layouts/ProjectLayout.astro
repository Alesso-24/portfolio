---
import Base from './Base.astro'

interface Props {
  title: string
  description: string
  badge: string
  coverImage: string
  coverAlt: string
  meta?: { label: string; value: string }[]
  backHref?: string
  ogImage?: string
  githubHref?: string
  githubLabel?: string
}

const {
  title,
  description,
  badge,
  coverImage,
  coverAlt,
  meta = [],
  backHref = '/portfolio/',
  ogImage,
  githubHref,
} = Astro.props
---

<Base
  title={`${title} — Alessandro Reyes`}
  description={description}
  ogImage={ogImage}
  canonical={`https://alesso-24.github.io${Astro.url.pathname}`}
>
  <article>
    <header style="
      padding: clamp(120px,18vh,180px) clamp(24px,5vw,80px) clamp(48px,7vh,80px);
      max-width: 1100px; margin: 0 auto;
    ">

      <!-- Back link (bilingual via CSS) -->
      <a href={backHref} class="back-link">
        <span>←</span>
        <span class="lang-en">All projects</span>
        <span class="lang-es">Todos los proyectos</span>
      </a>

      <!-- Badge label -->
      <div
        data-reveal
        style="
          display: flex; align-items: center; gap: 12px;
          font: 600 11px 'Hanken Grotesk', system-ui, sans-serif;
          letter-spacing: 0.18em; text-transform: uppercase;
          color: #6f6a5f; margin-bottom: clamp(16px, 2.5vh, 28px);
        "
      >
        <span style="width:8px; height:8px; border-radius:50%; background:#ea6a2e; flex-shrink:0;"></span>
        {badge}
      </div>

      <!-- Title -->
      <h1
        data-reveal
        data-reveal-delay="80"
        style="
          margin: 0 0 clamp(28px, 4vh, 52px);
          font-family: 'Instrument Serif', serif; font-weight: 400;
          font-size: clamp(28px, 4.4vw, 68px); line-height: 1.04;
          letter-spacing: -0.015em; max-width: 18ch;
          color: #211f1a;
        "
      >
        {title}
      </h1>

      <!-- Meta + actions -->
      {meta.length > 0 && (
        <div
          data-reveal
          data-reveal-delay="160"
          style="border-top: 1px solid rgba(33,31,26,0.1); padding-top: clamp(20px, 3vh, 32px);"
        >
          <div style="display: flex; flex-wrap: wrap; gap: clamp(20px, 3vw, 44px); margin-bottom: clamp(20px,3vh,28px);">
            {meta.map(({ label, value }) => (
              <div>
                <div style="font: 600 10px 'Hanken Grotesk', system-ui, sans-serif; letter-spacing: 0.16em; text-transform: uppercase; color: #6f6a5f; margin-bottom: 6px;">
                  {label}
                </div>
                <div style="font: 400 15px 'Hanken Grotesk', system-ui, sans-serif; color: #211f1a; line-height:1.5;" set:html={value} />
              </div>
            ))}
          </div>
          {githubHref && (
            <a
              href={githubHref}
              target="_blank"
              rel="noopener noreferrer"
              class="github-btn"
            >
              <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
              </svg>
              <span class="lang-en">View on GitHub ↗</span>
              <span class="lang-es">Ver en GitHub ↗</span>
            </a>
          )}
        </div>
      )}
    </header>

    <!-- Cover image -->
    <div
      data-reveal
      style="
        margin: 0 clamp(24px,5vw,80px) clamp(48px,7vh,80px);
        border-radius: 20px; overflow: hidden;
        box-shadow: 0 40px 100px -40px rgba(33,31,26,0.2);
      "
    >
      <img
        src={coverImage}
        alt={coverAlt}
        loading="eager"
        fetchpriority="high"
        decoding="async"
        style="width: 100%; height: auto; display: block; aspect-ratio: 16/9; object-fit: cover;"
      />
    </div>

    <!-- ── Page body ── slotted content gets project-body styles via is:global -->
    <div class="project-body">
      <slot />
    </div>
  </article>
</Base>

<!-- Scoped styles: only layout-level elements -->
<style>
  .back-link {
    display: inline-flex; align-items: center; gap: 8px;
    font: 600 11px 'Hanken Grotesk', system-ui, sans-serif;
    letter-spacing: 0.14em; text-transform: uppercase;
    color: #6f6a5f; text-decoration: none;
    margin-bottom: clamp(28px, 4vh, 48px);
    transition: color 0.2s;
  }
  .back-link:hover { color: #ea6a2e; }
  .back-link:focus-visible { outline: 2px solid #2540c0; outline-offset: 4px; border-radius: 4px; }

  .github-btn {
    display: inline-flex; align-items: center; gap: 9px;
    padding: 11px 22px; border-radius: 100px;
    border: 1.5px solid rgba(33,31,26,0.2);
    color: #211f1a; text-decoration: none;
    font: 600 13px 'Hanken Grotesk', system-ui, sans-serif;
    letter-spacing: 0.04em; transition: all 0.2s;
  }
  .github-btn:hover { background: rgba(33,31,26,0.06); border-color: rgba(33,31,26,0.4); }
  .github-btn:focus-visible { outline: 2px solid #2540c0; outline-offset: 3px; }
</style>

<!-- is:global: cascade into <slot /> content scoped to .project-body -->
<style is:global>
  .project-body {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 clamp(24px, 5vw, 80px) clamp(80px, 12vh, 140px);
  }

  /* ── Section heading ── */
  .project-body h2.section-h2 {
    font-family: 'Instrument Serif', serif;
    font-weight: 400;
    font-size: clamp(28px, 3.6vw, 48px);
    line-height: 1.08;
    letter-spacing: -0.015em;
    color: #211f1a;
    margin: clamp(60px, 9vh, 100px) 0 clamp(18px, 2.5vh, 28px);
  }

  /* ── Body prose ── */
  .project-body p.prose {
    font-size: clamp(15px, 1.35vw, 17.5px);
    line-height: 1.75;
    color: #534f46;
    margin: 0 0 clamp(18px, 2.5vh, 26px);
    max-width: 70ch;
  }

  /* ── Horizontal divider ── */
  .project-body hr.divider {
    border: none;
    border-top: 1px solid rgba(33,31,26,0.1);
    margin: clamp(44px, 7vh, 72px) 0;
  }

  /* ── Pull quote ── */
  .project-body .pull-quote {
    border-left: 3px solid #ea6a2e;
    margin: clamp(32px, 5vh, 52px) 0;
    padding: clamp(18px, 2.5vw, 28px) clamp(22px, 3vw, 36px);
    background: rgba(234,106,46,0.05);
    border-radius: 0 14px 14px 0;
  }
  .project-body .pull-quote p {
    margin: 0;
    font-family: 'Instrument Serif', serif;
    font-size: clamp(18px, 2.2vw, 28px);
    line-height: 1.38;
    color: #211f1a;
    font-style: italic;
  }

  /* ── Tech card grid ── */
  .project-body .tech-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: clamp(14px, 2vw, 22px);
    margin: clamp(28px, 4vh, 44px) 0;
  }
  .project-body .tech-card {
    background: #efe7d8;
    border-radius: 16px;
    padding: clamp(22px, 2.8vw, 32px);
    border: 1px solid rgba(33,31,26,0.07);
  }
  .project-body .tech-card .tech-num {
    font-family: 'Instrument Serif', serif;
    font-size: clamp(32px, 4vw, 52px);
    line-height: 1;
    letter-spacing: -0.02em;
    margin-bottom: 14px;
  }
  .project-body .tech-card h3 {
    font-family: 'Instrument Serif', serif;
    font-weight: 400;
    font-size: clamp(18px, 1.8vw, 24px);
    line-height: 1.2;
    color: #211f1a;
    margin: 0 0 10px;
  }
  .project-body .tech-card p {
    font-size: 14px;
    line-height: 1.68;
    color: #6f6a5f;
    margin: 0;
  }

  /* ── Callout box ── */
  .project-body .callout {
    background: rgba(37,64,192,0.05);
    border: 1px solid rgba(37,64,192,0.14);
    border-radius: 14px;
    padding: clamp(22px, 3vw, 36px);
    margin: clamp(32px, 4.5vh, 52px) 0;
    font-size: clamp(14px, 1.2vw, 16px);
    line-height: 1.7;
    color: #534f46;
  }
  .project-body .callout strong {
    display: block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #2540c0;
    margin-bottom: 12px;
  }

  /* ── Stat highlight ── */
  .project-body .stat-highlight {
    margin: clamp(32px, 5vh, 56px) 0;
    padding: clamp(28px, 4vw, 48px);
    background: #efe7d8;
    border-radius: 18px;
  }

  /* ── Video embed ── */
  .project-body .video-embed {
    position: relative; width: 100%; aspect-ratio: 16/9;
    border-radius: 18px; overflow: hidden;
    box-shadow: 0 32px 80px -28px rgba(37,64,192,0.32);
    margin: clamp(18px,2.5vh,28px) 0 clamp(44px,6.5vh,64px);
    background: #211f1a;
  }
  .project-body .video-embed iframe {
    position: absolute; inset: 0; width: 100%; height: 100%; border: none;
  }

  /* ── IEEE badge ── */
  .project-body .ieee-badge {
    display: inline-flex; align-items: center; gap: 10px;
    padding: 11px 22px; border-radius: 100px;
    background: rgba(37,64,192,0.07);
    border: 1px solid rgba(37,64,192,0.18);
    font: 700 11px 'Hanken Grotesk', system-ui, sans-serif;
    letter-spacing: 0.13em; text-transform: uppercase;
    color: #2540c0;
    margin: clamp(20px, 3vh, 36px) 0 0;
  }

  /* ── Responsive stat grid (used inside stat-highlight) ── */
  .project-body .stat-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(16px, 3vw, 40px);
  }
  @media (max-width: 480px) {
    .project-body .stat-grid { grid-template-columns: 1fr; gap: 24px; }
  }

  /* ── Two-image grid (responsive) ── */
  .project-body .img-grid-2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(12px, 2vw, 24px);
    margin-bottom: clamp(28px, 4vh, 48px);
  }
  @media (max-width: 480px) {
    .project-body .img-grid-2 { grid-template-columns: 1fr; }
  }

  /* ── Mobile padding override ── */
  @media (max-width: 560px) {
    .project-body { padding: 0 16px clamp(60px, 10vh, 100px); }
    .project-body h2.section-h2 { font-size: clamp(26px, 7vw, 36px); margin-top: clamp(44px, 7vh, 72px); }
    .project-body p.prose { font-size: 15px; }
    .project-body .pull-quote p { font-size: clamp(16px, 5vw, 22px); }
    .project-body .tech-grid { grid-template-columns: 1fr; }
    .project-body .stat-highlight { padding: clamp(18px, 4vw, 28px); }
  }
</style>
