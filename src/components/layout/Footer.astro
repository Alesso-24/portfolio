---
interface Props { lang?: 'en' | 'es' }
const { lang = 'en' } = Astro.props
const year = new Date().getFullYear()
---

<footer class="bg-cream border-t border-ink/10 py-8 px-[clamp(20px,4vw,60px)]">
  <div class="max-w-[1280px] mx-auto flex flex-col sm:flex-row items-center justify-between gap-4
              font-sans text-[11px] font-normal tracking-[0.1em] uppercase text-muted">
    <span>© {year} Alessandro Reyes</span>
    <span class="font-serif italic not-italic normal-case tracking-normal text-[13px] text-muted-soft">
      <span class="lang-en">Designed for the real world.</span>
      <span class="lang-es">Diseñado para el mundo real.</span>
    </span>
  </div>
</footer>
