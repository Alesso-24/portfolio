---
import { PROJECTS } from '../../data/content'
const [featured, ...rest] = PROJECTS
---

<section
  id="work"
  style="background:#efe7d8; padding:clamp(76px,12vh,150px) clamp(20px,4vw,60px);"
>
  <div style="max-width:1280px; margin:0 auto;">

    <!-- Section header -->
    <div style="margin-bottom:clamp(40px,6vh,80px);">
      <div
        data-reveal
        style="font:600 12px 'Hanken Grotesk',system-ui,sans-serif;
               letter-spacing:0.16em; text-transform:uppercase; color:#6f6a5f;
               display:flex; align-items:center; gap:12px; margin-bottom:20px;"
      >
        <span style="width:9px; height:9px; border-radius:50%; background:#ea6a2e; flex-shrink:0;"></span>
        <span class="lang-en">Selected Work</span>
        <span class="lang-es">Trabajo Seleccionado</span>
      </div>
      <h2
        data-reveal
        data-reveal-delay="80"
        style="margin:0;
               font-family:'Instrument Serif',serif; font-weight:400;
               font-size:clamp(32px,5vw,80px); line-height:0.98;
               letter-spacing:-0.01em;"
      >
        <span class="lang-en">Projects & <em style="font-style:italic; color:#ea6a2e;">real systems</em></span>
        <span class="lang-es">Proyectos & <em style="font-style:italic; color:#ea6a2e;">sistemas reales</em></span>
      </h2>
    </div>

    <!-- Featured card (large 16:9) -->
    <a
      href={featured.href}
      data-reveal
      class="project-card project-card--large"
      style="display:block; text-decoration:none; margin-bottom:clamp(16px,2vw,28px);
             border-radius:18px; overflow:hidden; position:relative;
             box-shadow:0 24px 60px -30px rgba(234,106,46,0.4);
             transition:transform 0.4s cubic-bezier(0.16,1,0.3,1), box-shadow 0.4s;"
    >
      <div style="aspect-ratio:16/9; overflow:hidden;">
        <img
          src={featured.image}
          alt={featured.imageAlt}
          loading="eager"
          fetchpriority="high"
          decoding="async"
          style="width:100%; height:100%; object-fit:cover;
                 transition:transform 0.6s cubic-bezier(0.16,1,0.3,1);"
          class="card-img"
        />
      </div>
      <div style="padding:clamp(20px,2.5vw,32px);">
        <div style="font:600 11px 'Hanken Grotesk',system-ui,sans-serif;
                    letter-spacing:0.14em; text-transform:uppercase; color:#6f6a5f;
                    margin-bottom:12px;">
          <span class="lang-en">{featured.tag.en}</span>
          <span class="lang-es">{featured.tag.es}</span>
        </div>
        <h3 style="margin:0 0 12px;
                   font-family:'Instrument Serif',serif; font-weight:400;
                   font-size:clamp(22px,2.4vw,36px); line-height:1.1;
                   color:#211f1a;">
          <span class="lang-en">{featured.title.en}</span>
          <span class="lang-es">{featured.title.es}</span>
        </h3>
        <p style="margin:0; font-size:clamp(14px,1.2vw,16px); line-height:1.55;
                  color:#534f46; max-width:60ch;">
          <span class="lang-en">{featured.description.en}</span>
          <span class="lang-es">{featured.description.es}</span>
        </p>
      </div>
    </a>

    <!-- Small cards grid (3 remaining) -->
    <div style="display:grid; grid-template-columns:1fr; gap:clamp(16px,2vw,28px);"
         class="cards-grid">
      {rest.map((project, i) => (
        <a
          href={project.href}
          data-reveal
          data-reveal-delay={String((i + 1) * 80)}
          class="project-card"
          style={`display:block; text-decoration:none;
                  border-radius:18px; overflow:hidden;
                  box-shadow:${project.shadowColor === 'blue'
                    ? '0 24px 60px -30px rgba(37,64,192,0.4)'
                    : '0 22px 50px -30px rgba(234,106,46,0.4)'};
                  transition:transform 0.4s cubic-bezier(0.16,1,0.3,1), box-shadow 0.4s;`}
        >
          <div style="aspect-ratio:4/3; overflow:hidden;">
            <img
              src={project.image}
              alt={project.imageAlt}
              loading="lazy"
              decoding="async"
              style="width:100%; height:100%; object-fit:cover;
                     transition:transform 0.6s cubic-bezier(0.16,1,0.3,1);"
              class="card-img"
            />
          </div>
          <div style="padding:clamp(16px,2vw,24px);">
            <div style="font:600 11px 'Hanken Grotesk',system-ui,sans-serif;
                        letter-spacing:0.14em; text-transform:uppercase; color:#6f6a5f;
                        margin-bottom:10px;">
              <span class="lang-en">{project.tag.en}</span>
              <span class="lang-es">{project.tag.es}</span>
            </div>
            <h3 style="margin:0 0 10px;
                       font-family:'Instrument Serif',serif; font-weight:400;
                       font-size:clamp(18px,1.8vw,26px); line-height:1.15;
                       color:#211f1a;">
              <span class="lang-en">{project.title.en}</span>
              <span class="lang-es">{project.title.es}</span>
            </h3>
            <p style="margin:0; font-size:clamp(13px,1.1vw,15px); line-height:1.55;
                      color:#534f46;">
              <span class="lang-en">{project.description.en}</span>
              <span class="lang-es">{project.description.es}</span>
            </p>
          </div>
        </a>
      ))}
    </div>

  </div>
</section>

<style>
  @media (min-width: 640px) {
    .cards-grid { grid-template-columns: repeat(2, 1fr) !important; }
  }
  @media (min-width: 1024px) {
    .cards-grid { grid-template-columns: repeat(3, 1fr) !important; }
  }
  .project-card:hover { transform: translateY(-4px); }
  .project-card:hover .card-img { transform: scale(1.04); }
  .project-card:focus-visible { outline: 2px solid #2540c0; outline-offset: 4px; }
</style>
