---
import { ABOUT } from '../../data/content'
---

<section
  id="about"
  style="background:#f3ede1; padding:clamp(76px,12vh,150px) clamp(20px,4vw,60px);"
>
  <div style="max-width:1280px; margin:0 auto;">

    <!-- Section label -->
    <div
      data-reveal
      style="font:600 12px 'Hanken Grotesk',system-ui,sans-serif;
             letter-spacing:0.16em; text-transform:uppercase; color:#6f6a5f;
             margin-bottom:clamp(32px,5vh,60px);
             display:flex; align-items:center; gap:12px;"
    >
      <span style="width:9px; height:9px; border-radius:50%; background:#ea6a2e; flex-shrink:0;"></span>
      <span class="lang-en">{ABOUT.label.en}</span>
      <span class="lang-es">{ABOUT.label.es}</span>
    </div>

    <div class="about-grid" style="display:grid; grid-template-columns:1fr; gap:clamp(34px,5vw,80px); align-items:end;">

      <!-- H2 serif big -->
      <h2
        data-reveal
        style="margin:0;
               font-family:'Instrument Serif',serif; font-weight:400;
               font-size:clamp(28px,4.4vw,66px); line-height:1.04;
               letter-spacing:-0.01em; max-width:18ch;"
      >
        <span class="lang-en">{ABOUT.h2.en.plain} <em style="font-style:italic; color:#2540c0;">{ABOUT.h2.en.italic}</em> {ABOUT.h2.en.end}</span>
        <span class="lang-es">{ABOUT.h2.es.plain} <em style="font-style:italic; color:#2540c0;">{ABOUT.h2.es.italic}</em> {ABOUT.h2.es.end}</span>
      </h2>

      <!-- Bio + availability -->
      <div class="about-bio" data-reveal data-reveal-delay="120" style="max-width:480px;">
        <div class="lang-en">
          {ABOUT.bio.en.map((p) => (
            <p style="margin:0 0 20px; font-size:clamp(15px,1.3vw,17px); line-height:1.6; color:#534f46;">{p}</p>
          ))}
        </div>
        <div class="lang-es">
          {ABOUT.bio.es.map((p) => (
            <p style="margin:0 0 20px; font-size:clamp(15px,1.3vw,17px); line-height:1.6; color:#534f46;">{p}</p>
          ))}
        </div>

        <p style="margin:24px 0 0; font:600 12px 'Hanken Grotesk',system-ui,sans-serif;
                  letter-spacing:0.12em; text-transform:uppercase; color:#6f6a5f;">
          <span class="lang-en">{ABOUT.availability.en}</span>
          <span class="lang-es">{ABOUT.availability.es}</span>
        </p>
      </div>

    </div>
  </div>
</section>

<style>
  @media (min-width: 900px) {
    .about-grid { grid-template-columns: 1fr 1fr !important; }
    .about-bio  { justify-self: end; }
  }
</style>
