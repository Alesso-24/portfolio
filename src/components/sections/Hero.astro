---
import { HERO } from '../../data/content'
---

<header
  id="top"
  class="hero-root"
>
  <!-- Aurora background -->
  <div
    data-parallax="hero-bg"
    style="position:absolute; inset:0; z-index:0; pointer-events:none;"
    aria-hidden="true"
  >
    <div style="position:absolute; width:48vw; height:48vw; left:40%; top:2%;
                background:radial-gradient(circle, #2540c0, transparent 62%);
                filter:blur(72px); opacity:0.5;
                animation:ar-drift1 17s ease-in-out infinite;"></div>
    <div style="position:absolute; width:40vw; height:40vw; left:56%; top:26%;
                background:radial-gradient(circle, #ea6a2e, transparent 60%);
                filter:blur(82px); opacity:0.42;
                animation:ar-drift2 20s ease-in-out infinite;"></div>
    <div style="position:absolute; width:32vw; height:32vw; left:48%; top:-4%;
                background:radial-gradient(circle, #fff6e9, transparent 60%);
                filter:blur(60px); opacity:0.6;
                animation:ar-drift3 23s ease-in-out infinite;"></div>
    <div style="position:absolute; inset:0;
                background:radial-gradient(125% 95% at 52% 42%, transparent 26%, rgba(243,237,225,0.58) 100%);"></div>
  </div>

  <!-- Label top-left -->
  <div
    data-kin
    class="hero-label"
    style="animation:ar-kin 1s cubic-bezier(0.16,1,0.3,1) both; animation-delay:40ms;"
  >
    <span style="display:inline-block; width:9px; height:9px; border-radius:50%; background:#ea6a2e; flex-shrink:0;"></span>
    {HERO.label}
  </div>

  <!-- Main content grid: text + portrait -->
  <div data-parallax="hero-text" class="hero-content">

    <!-- Left: text -->
    <div class="hero-text">
      <h1
        data-kin
        style="animation:ar-kin 1.05s cubic-bezier(0.16,1,0.3,1) both; animation-delay:120ms;
               margin:0 0 clamp(24px,3.5vh,40px);
               font-family:'Instrument Serif',serif; font-weight:400;
               font-size:clamp(38px,7.2vw,120px); line-height:0.96;
               letter-spacing:-0.015em; text-wrap:balance;"
      >
        <span class="lang-en">{HERO.h1.en.plain} <em style="font-style:italic; color:#ea6a2e;">{HERO.h1.en.italic}</em></span>
        <span class="lang-es">{HERO.h1.es.plain} <em style="font-style:italic; color:#ea6a2e;">{HERO.h1.es.italic}</em></span>
      </h1>

      <p
        data-kin
        style="animation:ar-kin 1.05s cubic-bezier(0.16,1,0.3,1) both; animation-delay:240ms;
               margin:0 0 clamp(28px,4vh,48px); max-width:42ch;
               font-size:clamp(15px,1.35vw,18px); line-height:1.55; color:#534f46;"
      >
        <span class="lang-en">{HERO.paragraph.en}</span>
        <span class="lang-es">{HERO.paragraph.es}</span>
      </p>

      <div
        data-kin
        style="animation:ar-kin 1.05s cubic-bezier(0.16,1,0.3,1) both; animation-delay:360ms;
               display:flex; gap:14px; flex-wrap:wrap;"
      >
        <a
          href="#work"
          class="cta-primary"
        >
          <span class="lang-en">{HERO.cta_primary.en}</span>
          <span class="lang-es">{HERO.cta_primary.es}</span>
          <span style="font-size:13px;">↗</span>
        </a>
        <a
          href="#contact"
          class="cta-secondary"
        >
          <span class="lang-en">{HERO.cta_secondary.en}</span>
          <span class="lang-es">{HERO.cta_secondary.es}</span>
        </a>
      </div>
    </div>

    <!-- Right: portrait -->
    <div class="hero-portrait" data-kin style="animation:ar-kin 1.2s cubic-bezier(0.16,1,0.3,1) both; animation-delay:200ms;">
      <div class="portrait-frame">
        <img
          src="/portfolio/images/Alessandro.webp"
          alt="Alessandro Reyes — Mechatronics Engineer"
          loading="eager"
          fetchpriority="high"
          decoding="async"
          class="portrait-img"
        />
        <!-- Decorative accent -->
        <div class="portrait-accent" aria-hidden="true"></div>
      </div>
    </div>

  </div><!-- /hero-content -->

  <!-- Scroll hint -->
  <div class="scroll-hint" aria-hidden="true">
    Scroll
    <span style="display:inline-block; width:1px; height:32px; background:linear-gradient(#8a8579, transparent);"></span>
  </div>
</header>

<style>
  .hero-root {
    position: relative;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: clamp(120px, 18vh, 180px) clamp(20px, 4vw, 60px) clamp(60px, 8vh, 100px);
    box-sizing: border-box;
    overflow: hidden;
  }

  .hero-label {
    position: absolute;
    top: clamp(88px, 13vh, 140px);
    left: clamp(20px, 4vw, 60px);
    z-index: 2;
    display: flex;
    align-items: center;
    gap: 12px;
    font: 600 12px 'Hanken Grotesk', system-ui, sans-serif;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #6f6a5f;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 1120px;
    display: flex;
    align-items: center;
    gap: clamp(32px, 5vw, 72px);
  }

  .hero-text { flex: 1; min-width: 0; }

  .cta-primary {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 15px 28px; border-radius: 100px;
    background: #2540c0; color: #f3ede1;
    text-decoration: none; font: 600 15px 'Hanken Grotesk', system-ui, sans-serif;
    transition: opacity 0.2s;
  }
  .cta-primary:hover { opacity: 0.85; }
  .cta-primary:focus-visible { outline: 2px solid #2540c0; outline-offset: 3px; }

  .cta-secondary {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 15px 28px; border-radius: 100px;
    background: transparent; border: 1px solid rgba(33,31,26,0.25);
    color: #211f1a;
    text-decoration: none; font: 600 15px 'Hanken Grotesk', system-ui, sans-serif;
    transition: all 0.2s;
  }
  .cta-secondary:hover { background: rgba(33,31,26,0.06); }
  .cta-secondary:focus-visible { outline: 2px solid #2540c0; outline-offset: 3px; }

  /* Portrait */
  .hero-portrait {
    flex-shrink: 0;
    width: clamp(160px, 22vw, 320px);
    position: relative;
    margin-right: clamp(8px, 2vw, 40px);
  }

  .portrait-frame {
    position: relative;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 32px 80px -20px rgba(37,64,192,0.35), 0 0 0 1px rgba(37,64,192,0.08);
  }

  .portrait-img {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: 3/4;
    object-fit: cover;
    object-position: center top;
  }

  /* Blue tint gradient overlay at bottom */
  .portrait-frame::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 35%;
    background: linear-gradient(to top, rgba(37,64,192,0.2), transparent);
    pointer-events: none;
  }

  /* Orange dot accent */
  .portrait-accent {
    position: absolute;
    bottom: -12px; right: -12px;
    width: 28px; height: 28px;
    border-radius: 50%;
    background: #ea6a2e;
    box-shadow: 0 0 0 6px #f3ede1;
  }

  /* Scroll hint */
  .scroll-hint {
    position: absolute;
    bottom: 28px; right: clamp(20px, 4vw, 60px);
    z-index: 2;
    display: flex; align-items: center; gap: 10px;
    font: 600 11px 'Hanken Grotesk', system-ui, sans-serif;
    letter-spacing: 0.14em; text-transform: uppercase; color: #8a8579;
  }

  /* Mobile: stack portrait below text */
  @media (max-width: 700px) {
    .hero-root { justify-content: flex-start; padding-top: clamp(110px, 17vh, 160px); }
    .hero-content { flex-direction: column; gap: 32px; }
    .hero-portrait { width: clamp(140px, 50vw, 220px); align-self: flex-start; }
    .scroll-hint { display: none; }
  }
</style>
