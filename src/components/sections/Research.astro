---
import { PUBLICATIONS } from '../../data/content'
---

<section
  id="research"
  style="background:#f3ede1; padding:clamp(76px,12vh,150px) clamp(20px,4vw,60px);"
>
  <div style="max-width:1280px; margin:0 auto;">

    <!-- Section label -->
    <div
      data-reveal
      style="font:600 12px 'Hanken Grotesk',system-ui,sans-serif;
             letter-spacing:0.16em; text-transform:uppercase; color:#6f6a5f;
             display:flex; align-items:center; gap:12px; margin-bottom:clamp(32px,5vh,60px);"
    >
      <span style="width:9px; height:9px; border-radius:50%; background:#ea6a2e; flex-shrink:0;"></span>
      <span class="lang-en">Research & Publications</span>
      <span class="lang-es">Investigación y Publicaciones</span>
    </div>

    <!-- Publication rows -->
    <div>
      {PUBLICATIONS.map((pub, i) => (
        <a
          href={pub.href}
          data-reveal
          data-reveal-delay={String(i * 100)}
          class="pub-row"
        >
          <!-- Number -->
          <span class="pub-num">
            {pub.number}
          </span>

          <!-- Title + venue + badge -->
          <div>
            <p style="margin:0 0 12px;
                      font-family:'Instrument Serif',serif; font-weight:400;
                      font-size:clamp(17px,1.7vw,24px); line-height:1.3;
                      color:#211f1a;">
              <span class="lang-en">{pub.title.en}</span>
              <span class="lang-es">{pub.title.es}</span>
            </p>
            <div style="display:flex; flex-wrap:wrap; align-items:center; gap:12px;">
              <span style="font:600 11px 'Hanken Grotesk',system-ui,sans-serif;
                           letter-spacing:0.14em; text-transform:uppercase; color:#6f6a5f;">
                {pub.venue}
              </span>
              <!-- IEEE status badge -->
              <span style="
                display:inline-flex; align-items:center; gap:6px;
                padding:4px 12px; border-radius:100px;
                background:rgba(37,64,192,0.08);
                font:600 10px 'Hanken Grotesk',system-ui,sans-serif;
                letter-spacing:0.12em; text-transform:uppercase; color:#2540c0;
              ">
                <span style="width:6px;height:6px;border-radius:50%;background:#2540c0;flex-shrink:0;"></span>
                <span class="lang-en">Accepted · IEEE Xplore pending</span>
                <span class="lang-es">Aceptado · IEEE Xplore pendiente</span>
              </span>
            </div>
          </div>

          <!-- Year + view link -->
          <div class="pub-year" style="display:flex; flex-direction:column; align-items:flex-end; gap:8px; padding-top:4px;">
            <span style="font:600 14px 'Hanken Grotesk',system-ui,sans-serif;
                         color:#2540c0; white-space:nowrap;">
              {pub.year}
            </span>
            <span style="
              display:inline-flex; align-items:center; gap:4px;
              font:600 10px 'Hanken Grotesk',system-ui,sans-serif;
              letter-spacing:0.1em; text-transform:uppercase; color:#6f6a5f;
              white-space:nowrap;
            ">
              <span class="lang-en">View case study</span>
              <span class="lang-es">Ver caso</span>
            </span>
          </div>
        </a>
      ))}

      <!-- Bottom border -->
      <div style="border-top:1px solid rgba(33,31,26,0.1);"></div>
    </div>

  </div>
</section>

<style>
  .pub-row {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: start;
    gap: clamp(12px, 2.5vw, 40px);
    padding: clamp(28px, 4vh, 48px) 0;
    border-top: 1px solid rgba(33,31,26,0.1);
    text-decoration: none;
    transition: opacity 0.2s;
  }
  .pub-row:hover  { opacity: 0.75; }
  .pub-row:focus-visible { outline: 2px solid #2540c0; outline-offset: 4px; border-radius: 4px; }

  .pub-num {
    font-family: 'Instrument Serif', serif;
    font-weight: 400;
    font-size: clamp(28px, 3.5vw, 52px);
    line-height: 1;
    color: #ea6a2e;
    letter-spacing: -0.01em;
    min-width: 2ch;
  }

  @media (max-width: 560px) {
    .pub-row { grid-template-columns: auto 1fr; }
    .pub-year { display: none !important; }
  }
</style>
