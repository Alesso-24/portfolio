---
import { PUBLICATIONS } from '../../data/content'
const lang = 'en'
---

<section
  id="research"
  style="background:#f3ede1; padding:clamp(76px,12vh,150px) clamp(20px,4vw,60px);"
>
  <div style="max-width:1280px; margin:0 auto;">

    <!-- Section label -->
    <div
      data-reveal
      style="font:600 12px 'Hanken Grotesk',system-ui,sans-serif;
             letter-spacing:0.16em; text-transform:uppercase; color:#6f6a5f;
             display:flex; align-items:center; gap:12px; margin-bottom:clamp(32px,5vh,60px);"
    >
      <span style="width:9px; height:9px; border-radius:50%; background:#ea6a2e; flex-shrink:0;"></span>
      {lang === 'en' ? 'Research & Publications' : 'Investigación y Publicaciones'}
    </div>

    <!-- Publication rows -->
    <div>
      {PUBLICATIONS.map((pub, i) => (
        <a
          href={pub.href}
          data-reveal
          data-reveal-delay={String(i * 100)}
          class="pub-row"
        >
          <!-- Number -->
          <span style="font-family:'Instrument Serif',serif; font-weight:400;
                       font-size:clamp(28px,3.5vw,52px); line-height:1;
                       color:#ea6a2e; letter-spacing:-0.01em; min-width:2ch;">
            {pub.number}
          </span>

          <!-- Title + venue -->
          <div>
            <p style="margin:0 0 10px;
                      font-family:'Instrument Serif',serif; font-weight:400;
                      font-size:clamp(16px,1.6vw,22px); line-height:1.35;
                      color:#211f1a;">
              {pub.title[lang]}
            </p>
            <span style="font:600 11px 'Hanken Grotesk',system-ui,sans-serif;
                         letter-spacing:0.14em; text-transform:uppercase; color:#6f6a5f;">
              {pub.venue}
            </span>
          </div>

          <!-- Year link -->
          <span class="pub-year" style="font:600 14px 'Hanken Grotesk',system-ui,sans-serif;
                       color:#2540c0; white-space:nowrap; padding-top:4px;">
            {pub.year}
          </span>
        </a>
      ))}

      <!-- Bottom border -->
      <div style="border-top:1px solid rgba(33,31,26,0.1);"></div>
    </div>

  </div>
</section>

<style>
  .pub-row {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: start;
    gap: clamp(12px, 2.5vw, 40px);
    padding: clamp(24px, 3.5vh, 40px) 0;
    border-top: 1px solid rgba(33,31,26,0.1);
    text-decoration: none;
    transition: opacity 0.2s;
  }
  .pub-row:hover  { opacity: 0.7; }
  .pub-row:focus-visible { outline: 2px solid #2540c0; outline-offset: 4px; border-radius: 4px; }
  /* On very small screens stack number + year beside title */
  @media (max-width: 440px) {
    .pub-row { grid-template-columns: auto 1fr; }
    .pub-year { display: none; }
  }
</style>
